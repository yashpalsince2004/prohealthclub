---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found" description="Oops! Page not found">
  <div class="flex min-h-screen items-center justify-center bg-gray-100">
    <div class="text-center">
      <h1 class="mb-4 text-4xl font-bold text-gray-900">404</h1>
      <p class="mb-4 text-xl text-gray-600">Oops! Page not found</p>
      <a href="/prohealthclub/" class="text-blue-500 underline hover:text-blue-700 font-semibold">
        Return to Home
      </a>
    </div>
  </div>
</Layout>
